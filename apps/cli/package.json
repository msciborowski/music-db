{
  "name": "@mdb/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "mdb": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clack/prompts": "1.6.0",
    "@mdb/core": "*",
    "@mdb/database": "*",
    "cli-progress": "3.12.0",
    "commander": "15.0.0",
    "dotenv": "17.4.2",
    "hash-wasm": "4.12.0",
    "jschardet": "3.1.4",
    "music-metadata": "11.13.0",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@types/cli-progress": "3.11.6",
    "@types/node": "26.1.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
