# --- Database ---
# PostgreSQL connection string used by Prisma (apps/api, apps/cli via @mdb/database).
DATABASE_URL="postgresql://mdb:mdb@localhost:5432/music_db?schema=public"

# --- Scan defaults (apps/cli) ---
# Default concurrency for FS walk / hashing / metadata read (§14: moderate 4-6).
MDB_CONCURRENCY=4

# --- BPM + key detection (computed, runs in the Fingerprint phase) ---
# External DSP tools, `{file}` is replaced with the audio path (its own argv token).
# Key -> Camelot (e.g. keyfinder-cli, libKeyFinder):
# MDB_KEY_CMD="keyfinder-cli {file}"
# BPM (e.g. aubio, or any tool that prints a BPM number):
# MDB_BPM_CMD="aubio tempo {file}"

# --- Enrich (phase 4, network) ---
# AcoustID API key (free): https://acoustid.org/api-key
# ACOUSTID_KEY=
# Discogs personal access token: https://www.discogs.com/settings/developers
# DISCOGS_TOKEN=
# Descriptive User-Agent for MusicBrainz/Discogs (recommended to set your own):
# MDB_USER_AGENT="MusicDB/0.1 ( you@example.com )"
